{
  "Type": "Abstract",
  "StartState": "Idle",
  "DefaultSubState": "Default",
  "Parameters": {
    "Appearance": {
      "Value": "Mannequin",
      "Description": "Model to be used."
    },
    "FlockArray": {
      "Value": [],
      "TypeHint": "String",
      "Description": "Array containing NPCs for this flock type."
    },
    "DropHexItem": {
      "Value": "Hex_Mannequin_Block",
      "Description": "Drop from Hex Creature"
    },
    "NameTranslationKey": {
      "Value": "server.npcRoles.Template.name",
      "Description": "Translation key for NPC name display"
    }
  },
  "IsMemory": false,
  "Appearance": {"Compute": "Appearance"},
  "DefaultNPCAttitude": "Ignore",
  "DefaultPlayerAttitude": "Ignore",
  "NameTranslationKey": {"Compute": "NameTranslationKey"},
  "FlockSpawnTypes": {"Compute": "FlockArray"},
  "FlockAllowedNPC": {"Compute": "FlockArray"},
  "InventorySize": 0,
  "HotbarSize": 3,
  "OffHandSlots": 1,
  "PickupDropOnDeath": true,
  "MotionControllerList": [
    {
      "Type": "Walk",
      "MaxWalkSpeed": 12,
      "Gravity": 10,
      "RunThreshold": 0.3,
      "MaxFallSpeed": 15,
      "MaxRotationSpeed": 360,
      "Acceleration": 10,
      "MaxClimbHeight": 10,
      "MaxDropHeight": 4
    }
  ],
  "MaxHealth": 10,
  "Instructions": [
    {
      "$Comment": "Adds the entity to the flock of the first player it finds",
      "Continue": true,
      "Instructions": [
        {
          "$Comment": "Add creature to flock",
          "Continue": true,
          "Sensor": {
            "Type": "Self",
            "Filters": [
              {
                "Type": "Flock",
                "FlockStatus": "NotMember"
              }
            ]
          },
          "Instructions": [
            {
              "Sensor": {
                "Type": "Player",
                "Range": 20
              },
              "Actions": [
                {
                  "Type": "JoinFlock",
                  "ForceJoin": true
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "$Comment": "Pick up item",
      "Continue": true,
      "Instructions": [
        {
          "Continue": true,
          "Sensor": {
            "Type": "Self",
            "Filters": [
              {
                "Type": "Inventory",
                "CountRange": [ 0, 100 ],
                "FreeSlotRange": [ 4, 4 ]
              }
            ]
          },
          "Instructions": [
            {
              "Sensor": {
                "Type": "DroppedItem",
                "Range": 5,
                "ViewSector": 180,
                "Items": [ "*Torch*" ]
              },
              "Actions": [
                {
                  "Type": "PickUpItem",
                  "Hoover": true
                }
              ],
              "BodyMotion": {
                "Type": "Seek",
                "StopDistance": 0.5
              }
            }
          ]
        }
      ]
    },
    {
      "$Comment": "Entity movement",
      "Instructions": [
        {
          "Sensor": {
            "Type": "State",
            "State": "Idle"
          },
          "Instructions": [
            {
              "Sensor": {
                "Type": "State",
                "State": ".Default"
              },
              "Instructions": [
                {
                  "$Comment": "Less than 1 block away from the leader",
                  "Sensor": {
                    "Type": "Player",
                    "Range": 1,
                    "ExcludeOwnType": true,
                    "Filters": [
                      {
                        "Type": "Flock",
                        "FlockStatus": "Leader"
                      }
                    ]
                  },
                  "HeadMotion": {
                    "Type": "Aim",
                    "Deflection": true,
                    "Spread": 1
                  },
                  "BodyMotion": {
                    "Type": "MaintainDistance",
                    "DesiredDistanceRange": [1.5, 1.5],
                    "MoveThreshold": 0.2,
                    "RelativeForwardsSpeed": 0.6,
                    "RelativeBackwardsSpeed": 0.3
                  }
                },
                {
                  "$Comment": "Less than 10 blocks away from the leader",
                  "Sensor": {
                    "Type": "Player",
                    "Range": 10,
                    "ExcludeOwnType": true,
                    "LockOnTarget": true,
                    "Filters": [
                      {
                        "Type": "Flock",
                        "FlockStatus": "Leader"
                      }
                    ]
                  },
                  "Instructions": [
                    {
                      "Sensor": {
                        "Type": "Target"
                      },
                      "BodyMotion": {
                        "Type": "Seek",
                        "SlowDownDistance": 5,
                        "StopDistance": 3,
                        "RelativeSpeed": 0.5
                      }
                    }
                  ]
                },
                {
                  "$Comment": "Teleports to the leader if more than 10 blocks away",
                  "Sensor": {
                    "Type": "And",
                    "Sensors": [
                      {
                        "Type": "FlockLeader"
                      },
                      {
                        "Type": "Self",
                        "Filters": [
                          {
                            "Type": "Flock",
                            "FlockStatus": "Member"
                          }
                        ]
                      }
                    ]
                  },
                  "BodyMotion": {
                    "Type": "TeleportHexCreature",
                    "OffsetRange": [2, 3],
                    "MinYOffset": 0.1,
                    "OffsetSector": 2,
                    "Orientation": "TowardsTarget"
                  },
                  "Actions": [
                    {
                      "Type": "SpawnParticles",
                      "Offset": [ 0, 0.5, 0 ],
                      "ParticleSystem": "Effect_Death",
                      "Once": true
                    },
                    {
                      "Type": "Timeout",
                      "Delay": [ 2, 2 ],
                      "DelayAfter": true
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}