{
  "StartState": "Idle",
  "DefaultSubState": "Default",
  "Type": "Abstract",
  "Invulnerable": true,
  "Parameters": {
    "Appearance": {
      "Value": "Mannequin",
      "Description": "Model to be used."
    },
    "FlockArray": {
      "Value": [],
      "TypeHint": "String",
      "Description": "Array containing NPCs for this flock type."
    },
    "DropHexItem": {
      "Value": "Hex_Mannequin_Block",
      "Description": "Drop from Hex Creature"
    },
    "NameTranslationKey": {
      "Value": "server.npcRoles.Template.name",
      "Description": "Translation key for NPC name display"
    }
  },
  "IsMemory": false,
  "BreathesInWater": true,
  "Appearance": {"Compute": "Appearance"},
  "DisableDamageFlock": true,
  "DefaultNPCAttitude": "Ignore",
  "DefaultPlayerAttitude": "Ignore",
  "FlockSpawnTypes": {"Compute": "FlockArray"},
  "FlockAllowedNPC": {"Compute": "FlockArray"},
  "ApplySeparation": true,
  "SeparationDistance": 2,
  "SeparationWeight": 1,
  "SeparationDistanceTarget": 0.5,
  "SeparationNearRadiusTarget": 2,
  "SeparationFarRadiusTarget": 7,
  "NameTranslationKey": {"Compute": "NameTranslationKey"},
  "MotionControllerList": [
    {
      "Type": "Walk",
      "MaxWalkSpeed": 12,
      "Gravity": 10,
      "RunThreshold": 0.3,
      "MaxFallSpeed": 15,
      "MaxRotationSpeed": 360,
      "Acceleration": 10,
      "MaxClimbHeight": 10,
      "MaxDropHeight": 5
    }
  ],
  "MaxHealth": 100,
  "Instructions": [
    {
      "Continue": true,
      "Instructions": [
        {
          "$Comment": "Add creature to flock",
          "Continue": true,
          "Sensor": {
            "Type": "Self",
            "Filters": [
              {
                "Type": "Flock",
                "FlockStatus": "NotMember"
              }
            ]
          },
          "Instructions": [
            {
              "Sensor": {
                "Type": "Player",
                "Range": 20
              },
              "Actions": [
                {
                  "Type": "JoinFlock",
                  "ForceJoin": true
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "Instructions": [
        {
          "Sensor": {
            "Type": "State",
            "State": "Despawn"
          },
          "ActionsAtomic": true,
          "Instructions": [
            {
              "Sensor": {
                "Type": "Any",
                "Once": true
              },
              "Actions": [
                {
                  "Type": "SpawnParticles",
                  "Offset": [ 0, 0.5, 0 ],
                  "ParticleSystem": "Effect_Death"
                },
                {
                  "Type": "DropItem",
                  "Item": {"Compute": "DropHexItem"},
                  "Distance": [ 0, 0 ],
                  "ThrowSpeed": 15,
                  "Once": true
                }
              ]
            },
            {
              "ActionsBlocking": true,
              "Actions": [
                {
                  "Type": "Despawn"
                }
              ]
            }
          ]
        },
        {
          "Sensor": {
            "Type": "State",
            "State": "Idle"
          },
          "Instructions": [
            {
              "Sensor": {
                "Type": "State",
                "State": ".Default"
              },
              "Instructions": [
                {
                  "Sensor": {
                    "Type": "Player",
                    "Range": 1,
                    "ExcludeOwnType": true,
                    "Filters": [
                      {
                        "Type": "Flock",
                        "FlockStatus": "Leader"
                      }
                    ]
                  },
                  "HeadMotion": {
                    "Type": "Aim",
                    "Deflection": true,
                    "Spread": 1
                  },
                  "BodyMotion": {
                    "Type": "MaintainDistance",
                    "DesiredDistanceRange": [1.5, 1.5],
                    "MoveThreshold": 0.2,
                    "RelativeForwardsSpeed": 0.6,
                    "RelativeBackwardsSpeed": 0.3
                  }
                },
                {
                  "Sensor": {
                    "Type": "Player",
                    "Range": 10,
                    "ExcludeOwnType": true,
                    "LockOnTarget": true,
                    "Filters": [
                      {
                        "Type": "Flock",
                        "FlockStatus": "Leader"
                      }
                    ]
                  },
                  "Instructions": [
                    {
                      "Sensor": {
                        "Type": "Target"
                      },
                      "BodyMotion": {
                        "Type": "Seek",
                        "SlowDownDistance": 5,
                        "StopDistance": 3,
                        "RelativeSpeed": 0.5
                      }
                    }
                  ]
                },
                {
                  "Sensor": {
                    "Type": "And",
                    "Sensors": [
                      {
                        "Type": "FlockLeader"
                      },
                      {
                        "Type": "Self",
                        "Filters": [
                          {
                            "Type": "Flock",
                            "FlockStatus": "Member"
                          }
                        ]
                      }
                    ]
                  },
                  "BodyMotion": {
                    "Type": "TeleportHexCreature",
                    "OffsetRange": [2, 3],
                    "MinYOffset": 0.1,
                    "OffsetSector": 2,
                    "Orientation": "TowardsTarget"
                  },
                  "Actions": [
                    {
                      "Type": "SpawnParticles",
                      "Offset": [ 0, 0.5, 0 ],
                      "ParticleSystem": "Effect_Death",
                      "Once": true
                    },
                    {
                      "Type": "Timeout",
                      "Delay": [ 2, 2 ],
                      "DelayAfter": true
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "InteractionInstruction": {
    "Instructions": [
      {
        "$Comment": "Activates interaction with the player if they are the leader",
        "Continue": true,
        "Sensor": {
          "Type": "And",
          "Sensors": [
            {
              "Type": "FlockLeader"
            },
            {
              "Type": "Self",
              "Filters": [
                {
                  "Type": "Flock",
                  "FlockStatus": "Member"
                }
              ]
            }
          ]
        },
        "Actions": [
          {
            "Type": "SetInteractable",
            "Interactable": true
          }
        ]
      },
      {
        "Sensor": {
          "Type": "HasInteracted"
        },
        "Instructions": [
          {
            "Actions": [
              {
                "Type": "LockOnInteractionTarget"
              },
              {
                "Type": "State",
                "State": "Despawn"
              }
            ]
          }
        ]
      }
    ]
  }
}